@model UsuarioModel;

<div class="text-center">
    <h1 class="display-4">Cadastro de usuario</h1>
</div>
<form asp-action="CadastrarUsuario" asp-controller="Usuario" method="post">     
    <div class="mb-3">
        <label asp-for="NomeUsuario">insira o nome agui</label>
        <input asp-for="NomeUsuario" class="form-control" />
    </div>
    <div class="mb-3">
        <label asp-for="IdadeUsuario" >idade</label>
        <input asp-for="IdadeUsuario" class="form-control" type="number" >
    </div>
    <button type="submit" class="btn-primary">Salvar Usuario</button>

</form>
@if(Model.MensagemErro.Any())
{
    @foreach(var e in Model.MensagemErro)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert" style="margin-top: 20px;" >
            <strong>ERRO @e.IdErro</strong> : @e.MensagemDeErro
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }
}

